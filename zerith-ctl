#!/usr/bin/env python3
"""
Operates on a running Zerith host (the @deploy subvolume mounted at /deploy and
the ESP mounted at /efi):

    @deploy/                         ESP/
      current  -> <id>                 zerith/current.efi
      fallback -> <id>                 zerith/fallback.efi
      staging  -> <id>   (transient)
      <id>/{root.cfs,zerith.efi,objects/,deployment.json}
      shared/objects/

Roles are relative symlinks; the ESP's current.efi / fallback.efi are what Limine
actually chainloads (each UKI carries deploy=<id> and the pinned composefs.digest=,
so the file names stay fixed while the contents change). This tool keeps the two
sides in step and reclaims space via hardlink-count GC.

The source of every deployment is a SIGNED OCI deployment artifact, pulled with
oras and verified with cosign before anything touches disk. Nothing is rendered
locally — the digest baked into the signed UKI is the digest that lands, and it
is re-checked here and again at boot.

Commands:
    status              show channel + current / fallback / staging
    deploy REF          set the update channel to REF, pull+verify it, promote
    update              pull the configured channel, promote if it changed
    rollback | swap     swap current <-> fallback
    gc                  drop unreferenced deployments and orphaned objects

The update channel (the artifact ref `update` pulls) lives in @deploy/source.conf,
seeded by the installer. Only `deploy` changes it — that's how you switch tag or
repo, e.g. `deploy ghcr.io/zerith-linux/zerith-nvidia:latest`.
"""
from __future__ import annotations

import argparse
import fcntl
import json
import os
import re
import shutil
import subprocess
import sys
import tarfile
import tempfile
from contextlib import contextmanager
from datetime import datetime, timezone
from pathlib import Path
from typing import Generator, NoReturn

DEFAULT_DEPLOY = Path("/deploy")
DEFAULT_ESP = Path("/efi")
SOURCE_CONF_NAME = "source.conf"
LOCK_NAME = ".zerith-ctl.lock"
CONFIG_SCHEMA = 1
META_SCHEMA = 1
ROLES = ("current", "fallback", "staging")

UKI_NAME = "zerith.efi"
CFS_NAME = "root.cfs"
META_NAME = "deployment.json"

DEFAULT_COSIGN_ISSUER = "https://token.actions.githubusercontent.com"

DRY_RUN = False
VERBOSE = False


# --------------------------------------------------------------------------- #
# Utilities (kept in step with install)
# --------------------------------------------------------------------------- #

def log(msg: str) -> None:
    print(f"zerith-ctl: {msg}")


def vlog(msg: str) -> None:
    if VERBOSE:
        log(msg)


def die(msg: str) -> "NoReturn":
    print(f"zerith-ctl: error: {msg}", file=sys.stderr)
    sys.exit(1)


def run(cmd: list[str], *, capture: bool = False, check: bool = True) -> str:
    printable = " ".join(cmd)
    if DRY_RUN and not capture:
        log(f"[dry-run] {printable}")
        return ""
    vlog(f"exec: {printable}")
    res = subprocess.run(cmd, text=True, capture_output=capture)
    if res.returncode != 0 and check:
        if capture and res.stderr:
            sys.stderr.write(res.stderr)
        die(f"command failed ({res.returncode}): {printable}")
    return (res.stdout or "").strip() if capture else ""


def now() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def require_root() -> None:
    if not DRY_RUN and os.geteuid() != 0:
        die("must run as root")


def require_tool(name: str) -> None:
    if not DRY_RUN and not shutil.which(name):
        die(f"required tool '{name}' not found on PATH")


@contextmanager
def deploy_lock(deploy: Path) -> "Generator[None, None, None]":
    if DRY_RUN:
        yield
        return
    lock_path = deploy / LOCK_NAME
    fd = os.open(lock_path, os.O_CREAT | os.O_RDWR, 0o600)
    try:
        try:
            fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            log("another zerith-ctl holds the lock; waiting…")
            fcntl.flock(fd, fcntl.LOCK_EX)
        yield
    finally:
        fcntl.flock(fd, fcntl.LOCK_UN)
        os.close(fd)


# --------------------------------------------------------------------------- #
# fs-verity helpers (see install for the rationale)
# --------------------------------------------------------------------------- #

def measure_file(path: Path) -> str:
    out = run(["fsverity", "digest", str(path)], capture=True)
    return out.split()[0].split(":", 1)[-1]


def enable_verity(path: Path) -> None:
    if DRY_RUN:
        log(f"[dry-run] fsverity enable {path}")
        return
    run(["fsverity", "enable", str(path)])


# --------------------------------------------------------------------------- #
# Roles (relative symlinks) + per-deployment metadata
# --------------------------------------------------------------------------- #

def deploy_dir(deploy: Path, deploy_id: str) -> Path:
    return deploy / deploy_id


def read_role(deploy: Path, role: str) -> str | None:
    link = deploy / role
    if not link.is_symlink():
        return None
    return os.path.basename(os.readlink(link))


def set_role(deploy: Path, role: str, deploy_id: str) -> None:
    link = deploy / role
    if DRY_RUN:
        log(f"[dry-run] ln -sfn {deploy_id} {link}")
        return
    tmp = deploy / f".{role}.tmp"
    if tmp.is_symlink() or tmp.exists():
        tmp.unlink()
    tmp.symlink_to(deploy_id)
    os.replace(tmp, link)
    vlog(f"role {role} -> {deploy_id}")


def clear_role(deploy: Path, role: str) -> None:
    link = deploy / role
    if DRY_RUN:
        log(f"[dry-run] rm -f {link}")
        return
    if link.is_symlink() or link.exists():
        link.unlink()
        vlog(f"role {role} cleared")


def write_meta(ddir: Path, *, deploy_id: str, version: str,
               digest: str, objects_ref: str | None, ref: str | None) -> None:
    meta = {
        "schema": META_SCHEMA,
        "deploy_id": deploy_id,
        "version": version,
        "composefs_digest": digest,
        "objects_ref": objects_ref,
        "ref": ref,
        "deployed_at": now(),
    }
    path = ddir / "deployment.json"
    if DRY_RUN:
        log(f"[dry-run] write {path}")
        vlog(json.dumps(meta, indent=2))
        return
    path.write_text(json.dumps(meta, indent=2) + "\n")
    vlog(f"wrote {path}")


def load_meta(deploy: Path, deploy_id: str | None) -> dict:
    if not deploy_id:
        return {}
    try:
        return json.loads((deploy_dir(deploy, deploy_id) / "deployment.json").read_text())
    except (OSError, ValueError):
        return {}


# --------------------------------------------------------------------------- #
# Update channel (central config)
# --------------------------------------------------------------------------- #

def read_source(config: Path) -> str | None:
    try:
        return json.loads(config.read_text()).get("ref")
    except (OSError, ValueError):
        return None


def write_source(config: Path, ref: str) -> None:
    data = {"schema": CONFIG_SCHEMA, "ref": ref, "updated_at": now()}
    if DRY_RUN:
        log(f"[dry-run] write {config} (ref={ref})")
        return
    config.parent.mkdir(parents=True, exist_ok=True)
    tmp = config.with_name(config.name + ".tmp")
    tmp.write_text(json.dumps(data, indent=2) + "\n")
    os.replace(tmp, config)
    vlog(f"update channel -> {ref}")


# --------------------------------------------------------------------------- #
# ESP UKIs
# --------------------------------------------------------------------------- #

def esp_uki(esp: Path, role: str) -> Path:
    return esp / "zerith" / f"{role}.efi"


def atomic_copy(src: Path, dst: Path) -> None:
    if DRY_RUN:
        log(f"[dry-run] cp {src} -> {dst}")
        return
    dst.parent.mkdir(parents=True, exist_ok=True)
    tmp = dst.with_name(f".{dst.name}.tmp")
    shutil.copy2(src, tmp)
    os.replace(tmp, dst)
    vlog(f"copied {src} -> {dst}")


# --------------------------------------------------------------------------- #
# OCI ref helpers (oras + cosign)
# --------------------------------------------------------------------------- #

def cosign_verify(ref: str, identity_re: str | None, issuer: str,
                  skip: bool) -> None:
    if skip:
        log(f"WARNING: skipping signature verification for {ref}")
        return
    if not identity_re:
        die("cosign identity not set (pass --cosign-identity or "
            "ZERITH_COSIGN_IDENTITY, or --insecure-skip-verify for dev)")
    require_tool("cosign")
    run(["cosign", "verify",
         "--certificate-identity-regexp", identity_re,
         "--certificate-oidc-issuer", issuer,
         ref], capture=True)
    vlog(f"cosign verified {ref}")


# --------------------------------------------------------------------------- #
# Source image (signed OCI deployment artifact)
# --------------------------------------------------------------------------- #

class Source:
    def __init__(self, staging: Path, meta: dict, *, ref: str,
                 cleanup=None):
        self.staging = staging
        self.meta = meta
        self.ref = ref
        self._cleanup = cleanup

    @property
    def uki(self) -> Path:
        return self.staging / UKI_NAME

    @property
    def root_cfs(self) -> Path:
        return self.staging / CFS_NAME

    @property
    def deploy_id(self) -> str:
        return self.meta["deploy_id"]

    @property
    def version(self) -> str:
        return self.meta.get("version", "unknown")

    @property
    def digest(self) -> str:
        return self.meta["composefs_digest"]

    @property
    def objects_ref(self) -> str | None:
        return self.meta.get("objects_ref")

    def cleanup(self) -> None:
        if self._cleanup:
            self._cleanup()


def source_from_ref(ref: str, cos_id: str | None, cos_issuer: str,
                    skip_verify: bool) -> Source:
    require_tool("oras")
    cosign_verify(ref, cos_id, cos_issuer, skip_verify)
    staging = Path(tempfile.mkdtemp(prefix="zerith-pull-"))
    run(["oras", "pull", ref, "-o", str(staging)])
    try:
        meta = json.loads((staging / META_NAME).read_text())
    except (OSError, ValueError) as e:
        shutil.rmtree(staging, ignore_errors=True)
        die(f"bad or missing {META_NAME} in {ref}: {e}")
    if not meta.get("deploy_id") and not DRY_RUN:
        die(f"artifact {ref} has no deploy_id in {META_NAME}")
    return Source(staging, meta, ref=ref,
                  cleanup=lambda: shutil.rmtree(staging, ignore_errors=True))


# --------------------------------------------------------------------------- #
# Object landing + stage / promote / rollback / gc
# --------------------------------------------------------------------------- #

# composefs stores each file's content under objects/<2 hex>/<rest>, named by
# its fs-verity (sha256) digest. `composefs-info dump` prints that digest for
# every regular file, so it tells us exactly which objects an image references.
_DIGEST_RE = re.compile(r"\b[0-9a-f]{64}\b")


def place_object(tmp: Path, shared: Path, rel: str) -> bool:
    dest = shared / rel
    if dest.exists():
        return False
    want = rel.replace("/", "")
    got = measure_file(tmp)
    if got != want:
        die(f"object digest mismatch: {rel} (measured {got})")
    dest.parent.mkdir(parents=True, exist_ok=True)
    os.replace(tmp, dest)
    enable_verity(dest)
    return True


_OBJ_PATH_RE = re.compile(r"^[0-9a-f]{2}/[0-9a-f]{2,}$")


def land_objects_from_ref(objects_ref: str, shared: Path) -> None:
    """Download the objects artifact (deterministic per-prefix tar shards) and
    extract any objects we don't already have, verifying each one's fs-verity
    digest against its store path and sealing it. One blob per shard keeps the
    transfer small; per-object dedup still happens at extract time on disk."""
    require_tool("oras")
    staging = Path(tempfile.mkdtemp(prefix="zerith-obj-"))
    try:
        run(["oras", "pull", objects_ref, "-o", str(staging)])
        fetched = present = 0
        for tarpath in sorted(staging.glob("*.tar")):
            with tarfile.open(tarpath) as tf:
                for m in tf.getmembers():
                    if not m.isfile():
                        continue
                    rel = (m.name[len("objects/"):]
                           if m.name.startswith("objects/") else m.name)
                    if not _OBJ_PATH_RE.match(rel):
                        continue            # not an object path; ignore
                    dest = shared / rel
                    if dest.exists():
                        present += 1
                        continue
                    if DRY_RUN:
                        log(f"[dry-run] extract object {rel}")
                        continue
                    extracted = tf.extractfile(m)
                    if extracted is None:
                        continue
                    dest.parent.mkdir(parents=True, exist_ok=True)
                    tmp = dest.parent / f".{rel.replace('/', '_')}.tmp"
                    with open(tmp, "wb") as out:
                        shutil.copyfileobj(extracted, out)
                    if place_object(tmp, shared, rel):
                        fetched += 1
                    else:
                        present += 1
    finally:
        shutil.rmtree(staging, ignore_errors=True)
    log(f"objects: extracted {fetched} new, {present} already present")


def referenced_objects(root_cfs: Path) -> set[str]:
    """Object store paths ("ab/cdef…") referenced by a single composefs image."""
    dump = run(["composefs-info", "dump", str(root_cfs)], capture=True)
    return {f"{d[:2]}/{d[2:]}" for d in _DIGEST_RE.findall(dump)}


def link_holder(shared: Path, holder: Path, root_cfs: Path) -> None:
    """Hardlink exactly this deployment's objects from the shared store into its
    private holder dir, bumping each referenced object's link count by one. GC
    keys off that count to know when an object has no remaining holders."""
    require_tool("composefs-info")
    holder.mkdir(parents=True, exist_ok=True)
    linked = 0
    for rel in referenced_objects(root_cfs):
        src = shared / rel
        if not src.is_file():
            continue
        dst = holder / rel
        dst.parent.mkdir(parents=True, exist_ok=True)
        try:
            os.link(src, dst)
            linked += 1
        except FileExistsError:
            pass
    vlog(f"holder: linked {linked} object(s) for this deployment")


def stage(deploy: Path, src: Source) -> None:
    """Materialize a deployment on disk and mark it `staging`. Idempotent.

    Replaces the old local `mkcomposefs` render: objects are FETCHED from the
    signed objects artifact (only the missing ones), root.cfs is COPIED from the
    verified deployment artifact, and its digest is checked against the signed
    value before it's trusted.
    """
    shared = deploy / "shared" / "objects"
    ddir = deploy_dir(deploy, src.deploy_id)
    holder = ddir / "objects"
    root_cfs = ddir / "root.cfs"
    btrfs_uki = ddir / "zerith.efi"

    if not DRY_RUN and not src.uki.is_file():
        die(f"deployment artifact has no {UKI_NAME}")
    if not src.objects_ref:
        die("deployment metadata has no objects_ref")

    if (not DRY_RUN) and root_cfs.exists():
        log(f"deployment {src.deploy_id} already on disk, reusing")
    else:
        if DRY_RUN:
            log(f"[dry-run] mkdir -p {ddir}")
        else:
            ddir.mkdir(parents=True, exist_ok=True)

        # 1. Land this image's objects into the shared store (verify + seal).
        land_objects_from_ref(src.objects_ref, shared)

        # 2. Place + seal root.cfs, then verify against the signed digest.
        if DRY_RUN:
            log(f"[dry-run] cp {src.root_cfs} -> {root_cfs}; verify {src.digest}")
        else:
            shutil.copy2(src.root_cfs, root_cfs)
            enable_verity(root_cfs)
            got = measure_file(root_cfs)
            if got != src.digest:
                die(f"root.cfs digest mismatch: expected {
                    src.digest}, got {got}")
            vlog("root.cfs digest verified against signed metadata")

        # 3. Holder hardlinks for GC (only this image's objects).
        if DRY_RUN:
            log(f"[dry-run] hardlink referenced objects into {holder}")
        else:
            link_holder(shared, holder, root_cfs)

        # 4. Keep the deployment's UKI with it.
        if DRY_RUN:
            log(f"[dry-run] cp {src.uki} -> {btrfs_uki}")
        else:
            shutil.copy2(src.uki, btrfs_uki)

        write_meta(ddir, deploy_id=src.deploy_id, version=src.version,
                   digest=src.digest, objects_ref=src.objects_ref, ref=src.ref)

    set_role(deploy, "staging", src.deploy_id)


def promote(deploy: Path, esp: Path, new_id: str) -> None:
    """Make `new_id` the current deployment; demote the old current to fallback."""
    old_current = read_role(deploy, "current")
    if new_id == old_current:
        log(f"{new_id} is already current; nothing to promote")
        clear_role(deploy, "staging")
        return

    new_uki = deploy_dir(deploy, new_id) / "zerith.efi"
    if not DRY_RUN and not new_uki.is_file():
        die(f"staged UKI missing: {new_uki}")

    # ESP first, in crash-safe order: keep a valid fallback before swinging
    # current to the new image. (Boot reads the ESP, not the role symlinks.)
    cur_efi = esp_uki(esp, "current")
    if old_current is not None and (DRY_RUN or cur_efi.is_file()):
        atomic_copy(cur_efi, esp_uki(esp, "fallback"))
    atomic_copy(new_uki, cur_efi)

    if old_current is not None:
        set_role(deploy, "fallback", old_current)
    set_role(deploy, "current", new_id)
    clear_role(deploy, "staging")

    gc(deploy)
    log(f"promoted {new_id}" + (f" (previous current {old_current} -> fallback)"
                                if old_current else ""))


def rollback(deploy: Path, esp: Path) -> None:
    """Swap current <-> fallback on both the ESP and the role symlinks."""
    cur = read_role(deploy, "current")
    fb = read_role(deploy, "fallback")
    if fb is None:
        die("no fallback deployment to roll back to")

    cur_efi = esp_uki(esp, "current")
    fb_efi = esp_uki(esp, "fallback")
    if not DRY_RUN and not fb_efi.is_file():
        die(f"fallback UKI missing on ESP: {fb_efi}")

    if DRY_RUN:
        log(f"[dry-run] swap {cur_efi} <-> {fb_efi}")
    else:
        tmp = cur_efi.with_name(".swap.efi.tmp")
        shutil.copy2(cur_efi, tmp)
        os.replace(fb_efi, cur_efi)
        os.replace(tmp, fb_efi)
        vlog("swapped ESP UKIs")

    set_role(deploy, "current", fb)
    if cur is not None:
        set_role(deploy, "fallback", cur)
    log(f"rolled back: current is now {fb} (was {cur})")


def _collect_stale(deploy: Path) -> list[Path]:
    """Deployment dirs eligible for removal: real dirs, not 'shared', not a
    dotfile, and not currently targeted by a role symlink."""
    protected = {read_role(deploy, r) for r in ROLES}
    protected.discard(None)
    stale = []
    for p in sorted(deploy.iterdir()):
        if p.is_symlink() or not p.is_dir():
            continue
        if p.name == "shared" or p.name.startswith(".") or p.name in protected:
            continue
        stale.append(p)
    return stale


def _try(fn) -> None:
    """Run a filesystem op, ignoring races/permission noise."""
    try:
        fn()
    except OSError:
        pass


def _sweep_objects(shared: Path) -> int:
    """Unlink objects with no remaining holder (link count == 1), then prune the
    now-empty fanout dirs. Returns how many objects were removed."""
    if not shared.is_dir():
        return 0
    swept = 0
    for root, _, files in os.walk(shared):
        for name in files:
            fp = Path(root) / name
            try:
                orphan = fp.stat().st_nlink == 1
            except OSError:
                continue
            if orphan:
                _try(fp.unlink)
                swept += 1
    for root, dirs, _ in os.walk(shared, topdown=False):
        for d in dirs:
            _try((Path(root) / d).rmdir)
    return swept


def gc(deploy: Path) -> None:
    """Remove any deployment not held by a role, then sweep orphaned objects.

    Object GC is by hardlink count: a shared object referenced by K live
    deployments has link count 1 + K, so count == 1 means no holder references
    it any more.
    """
    shared = deploy / "shared" / "objects"
    stale = _collect_stale(deploy)

    for p in stale:
        if DRY_RUN:
            log(f"[dry-run] rm -rf {p}")
        else:
            shutil.rmtree(p)
            vlog(f"removed deployment {p.name}")

    if DRY_RUN:
        log(f"[dry-run] sweep orphaned objects in {shared} (link count == 1)")
        return

    swept = _sweep_objects(shared)
    if stale:
        extra = f"; {swept} orphan object(s)" if swept else ""
        log(f"gc: removed {len(stale)} deployment(s): "
            f"{', '.join(p.name for p in stale)}{extra}")
    else:
        vlog("gc: nothing to remove")


# --------------------------------------------------------------------------- #
# Status
# --------------------------------------------------------------------------- #

def status(deploy: Path, config: Path) -> None:
    print(f"channel   {read_source(config) or '(unset — run deploy REF)'}")
    for role in ROLES:
        rid = read_role(deploy, role)
        if rid is None:
            print(f"{role:8}  -")
            continue
        meta = load_meta(deploy, rid)
        ver = meta.get("version", "?")
        ref = meta.get("ref") or "-"
        print(f"{role:8}  {rid}  version={ver}  ref={ref}")


# --------------------------------------------------------------------------- #
# Orchestration
# --------------------------------------------------------------------------- #

def do_deploy(deploy: Path, esp: Path, ref: str, cos_id: str | None,
              cos_issuer: str, skip_verify: bool) -> None:
    src = source_from_ref(ref, cos_id, cos_issuer, skip_verify)
    try:
        if src.deploy_id == read_role(deploy, "current"):
            log(f"already on {src.deploy_id} (version {
                src.version}); up to date")
            return
        stage(deploy, src)
        promote(deploy, esp, src.deploy_id)
        log(f"now current: {src.deploy_id} (version {src.version})")
    finally:
        src.cleanup()


def check_layout(deploy: Path, esp: Path) -> None:
    if DRY_RUN:
        return
    if not (deploy / "shared" / "objects").is_dir():
        die(f"{deploy} doesn't look like a Zerith @deploy mount "
            f"(no shared/objects) — point --deploy at it")
    if not (esp / "zerith").is_dir():
        die(f"{esp} doesn't look like the Zerith ESP (no zerith/) — point --esp at it")


# --------------------------------------------------------------------------- #
# CLI
# --------------------------------------------------------------------------- #

def main(argv: list[str] | None = None) -> int:
    global DRY_RUN, VERBOSE

    p = argparse.ArgumentParser(
        prog="zerith-ctl",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--deploy", type=Path, default=DEFAULT_DEPLOY,
                   help="@deploy subvolume mountpoint (default /deploy)")
    p.add_argument("--esp", type=Path, default=DEFAULT_ESP,
                   help="ESP mountpoint (default /efi)")
    p.add_argument("--config", type=Path, default=None,
                   help="update-channel config file (default <deploy>/source.conf)")
    p.add_argument("--cosign-identity",
                   default=os.environ.get("ZERITH_COSIGN_IDENTITY"),
                   help="cosign --certificate-identity-regexp "
                        "(env ZERITH_COSIGN_IDENTITY)")
    p.add_argument("--cosign-issuer",
                   default=os.environ.get("ZERITH_COSIGN_ISSUER",
                                          DEFAULT_COSIGN_ISSUER),
                   help="cosign --certificate-oidc-issuer")
    p.add_argument("--insecure-skip-verify", action="store_true",
                   help="DEV ONLY: skip cosign verification")
    p.add_argument("--dry-run", action="store_true",
                   help="print actions without changing anything")
    p.add_argument("-v", "--verbose", action="store_true")

    sub = p.add_subparsers(dest="cmd", required=True)
    sub.add_parser("status", help="show current / fallback / staging")

    d = sub.add_parser(
        "deploy", help="set the update channel to REF, pull+verify it, and promote")
    d.add_argument(
        "ref", help="signed artifact ref, e.g. ghcr.io/zerith-linux/zerith:latest")

    sub.add_parser(
        "update", help="pull the configured channel and promote if it changed")

    sub.add_parser("rollback", aliases=[
                   "swap"], help="swap current <-> fallback")
    sub.add_parser(
        "gc", help="remove unreferenced deployments and orphaned objects")

    args = p.parse_args(argv)
    DRY_RUN = args.dry_run
    VERBOSE = args.verbose
    deploy, esp = args.deploy, args.esp
    config = args.config or (deploy / SOURCE_CONF_NAME)

    if args.cmd == "status":
        status(deploy, config)
        return 0

    require_root()
    check_layout(deploy, esp)

    with deploy_lock(deploy):
        if args.cmd == "gc":
            gc(deploy)
        elif args.cmd in ("rollback", "swap"):
            rollback(deploy, esp)
        elif args.cmd == "deploy":
            do_deploy(deploy, esp, args.ref, args.cosign_identity,
                      args.cosign_issuer, args.insecure_skip_verify)
            write_source(config, args.ref)
        elif args.cmd == "update":
            ref = read_source(config)
            if not ref:
                die(f"no update channel configured in {config}; "
                    f"run 'deploy REF' first")
            log(f"update: pulling configured channel {ref}")
            do_deploy(deploy, esp, ref, args.cosign_identity,
                      args.cosign_issuer, args.insecure_skip_verify)

    return 0


if __name__ == "__main__":
    sys.exit(main())

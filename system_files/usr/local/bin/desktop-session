#!/bin/sh

LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}"
LOG_FILE="$LOG_DIR/desktop-session.log"

mkdir -p "$LOG_DIR"

MANGO_CONFIG="$HOME/.config/mango/config.conf"
[ -f "$MANGO_CONFIG" ] || MANGO_CONFIG="/etc/zerith/mango.conf"

VIBEPANEL_CONFIG="$HOME/.config/vibepanel/config.toml"
[ -f "$VIBEPANEL_CONFIG" ] || VIBEPANEL_CONFIG="/etc/zerith/vibepanel.toml"

pipewire >>"$LOG_FILE" 2>&1 &
wireplumber >>"$LOG_FILE" 2>&1 &
pipewire-pulse >>"$LOG_FILE" 2>&1 &

exec mango -c "$MANGO_CONFIG" \
    -s "vibepanel --config '$VIBEPANEL_CONFIG' & awww-daemon & veilad &" \
    >>"$LOG_FILE" 2>&1

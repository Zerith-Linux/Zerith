#!/bin/sh
# Zerith initramfs init: bring up the composefs root with writable state, then
# hand off to the real init. Any failure drops to a rescue shell.
export PATH=/sbin:/bin:/usr/sbin:/usr/bin

die()   { echo "FATAL: $*"; exec sh; }
retry() {                       # retry <tries> <cmd...> — returns 0 once cmd succeeds
    tries="$1"; shift
    while ! "$@"; do
        tries=$((tries - 1))
        [ "$tries" -le 0 ] && return 1
        sleep 1
    done
}

# --- API filesystems + console -------------------------------------------------
mount -t proc     proc  /proc
mount -t sysfs    sysfs /sys
mount -t devtmpfs dev   /dev
exec < /dev/console > /dev/console 2>&1

# --- storage + filesystem drivers ----------------------------------------------
# vmd before nvme so an SSD behind Intel VMD/RST is found; the rest cover
# NVMe/SATA/USB/eMMC. Builtin or absent modules report "not found" harmlessly.
for m in virtio_pci virtio_blk vmd nvme ahci sd_mod \
         usb_storage uas xhci_pci ehci_pci sdhci_pci mmc_block \
         fat vfat ext4 btrfs loop erofs overlay; do
    modprobe "$m" >/dev/null 2>&1
done

fs_ready() { grep -q "[[:space:]]$1\$" /proc/filesystems; }
for fs in erofs overlay; do
    retry 5 fs_ready "$fs" || die "$fs never registered"
done
[ -e /dev/loop-control ] || die "loop not available"

# --- pick deploy, locate the boot device ----------------------------------------
BOOTDEV="LABEL=zerith"
for arg in $(cat /proc/cmdline); do
    case "$arg" in deploy=*) deploy="${arg#deploy=}" ;; esac
done

resolve_dev() { DEV="$(findfs "$BOOTDEV" 2>/dev/null)"; [ -b "$DEV" ]; }
retry 20 resolve_dev || die "$BOOTDEV not found"

mkdir -p /mnt /sysroot
mount "$DEV" /mnt || die "mount $DEV failed"
# /mnt is the top-level subvol; the deployment store lives in the @deploy
# subvol, which appears here as the directory "@deploy".
BASE="/mnt/@deploy/$deploy"

# --- composefs root ------------------------------------------------------------
# composefs needs a real loop device and there's no udev here to make one;
# priming an erofs loop mount first gets the kernel to set one up.
mkdir -p /tmp/prime
mount -t erofs -o loop "$BASE/root.cfs" /tmp/prime
mount.composefs "$BASE/root.cfs" /sysroot -o basedir=/mnt/@deploy/shared/objects \
    || die "composefs mount failed"

EFIDEV="$(findfs LABEL=efi-zerith 2>/dev/null)"
[ -n "$EFIDEV" ] && [ -b "$EFIDEV" ] || die "EFI partition not found"

mount -t vfat "$EFIDEV" /sysroot/boot || die "EFI mount failed"

# --- writable state (mount /var before the /etc overlay) -----------------------
mount -t btrfs -o subvol=@var  "$DEV" /sysroot/var  || die "var mount failed"
mount -t btrfs -o subvol=@home "$DEV" /sysroot/home || die "home mount failed"
mount -t btrfs -o subvol=@deploy "$DEV" /sysroot/deploy || die "deploy mount failed"

# first boot / factory reset: seed an empty @var from the read-only factory copy
if [ -z "$(ls -A /sysroot/var 2>/dev/null)" ]; then
    echo "seeding /var from factory"
    cp -a /sysroot/usr/share/factory/var/. /sysroot/var/
fi

# /etc overlay: upper/work live on @var so edits survive cascade updates
mkdir -p /sysroot/var/lib/etc/upper /sysroot/var/lib/etc/work
mount -t overlay overlay /sysroot/etc \
    -o lowerdir=/sysroot/usr/etc,upperdir=/sysroot/var/lib/etc/upper,workdir=/sysroot/var/lib/etc/work \
    || die "etc overlay failed"

# --- hand off ------------------------------------------------------------------
mount -o bind /dev /sysroot/dev
mount -t tmpfs -o mode=0755,nosuid,nodev tmpfs /sysroot/run
exec switch_root /sysroot /sbin/init

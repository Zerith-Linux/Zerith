#!/bin/sh
export PATH=/sbin:/bin:/usr/sbin:/usr/bin

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs dev /dev
exec < /dev/console > /dev/console 2>&1

# load modules (builtins report "not found" — harmless; the guard below is the real check)
for m in virtio_pci virtio_blk ext4 btrfs loop erofs overlay; do
    modprobe "$m" >/dev/null 2>&1
done

# composefs needs erofs + overlay registered and loop available before it can mount
for fs in erofs overlay; do
    i=0
    until grep -q "[[:space:]]${fs}\$" /proc/filesystems; do
        i=$((i+1)); [ "$i" -ge 5 ] && { echo "FATAL: $fs never registered"; exec sh; }
        sleep 1
    done
done
[ -e /dev/loop-control ] || { echo "FATAL: loop not available"; exec sh; }

slot=a
BOOTDEV=""
for arg in $(cat /proc/cmdline); do
    case "$arg" in
        slot=*) slot="${arg#slot=}" ;;
        boot=*) BOOTDEV="${arg#boot=}" ;;
    esac
done
[ -n "$BOOTDEV" ] || { echo "Missing boot="; exec sh; }

n=0
while [ ! -b "$BOOTDEV" ] && [ "$n" -lt 10 ]; do sleep 1; n=$((n+1)); done

mkdir -p /mnt /sysroot
mount "$BOOTDEV" /mnt || { echo "mount $BOOTDEV failed"; exec sh; }

BASE="/mnt/deploy/$slot"

# composefs needs a real, initialized loop device to mount the EROFS image, and
# there's no udev here to create one — prime one the way busybox does.
mkdir -p /tmp/prime
mount -t erofs -o loop "$BASE/root.cfs" /tmp/prime

/sbin/mount.composefs "$BASE/root.cfs" /sysroot \
    -o basedir=/mnt/deploy/shared/objects \
    || { echo "composefs mount failed"; exec sh; }

# writable state over the read-only root (must mount /var BEFORE the /etc overlay)
mount -t btrfs -o subvol=@var  "$BOOTDEV" /sysroot/var  || { echo "var mount failed";  exec sh; }
mount -t btrfs -o subvol=@home "$BOOTDEV" /sysroot/home || { echo "home mount failed"; exec sh; }

# first boot / after factory reset: empty @var -> seed it from the read-only factory copy
if [ -z "$(ls -A /sysroot/var 2>/dev/null)" ]; then
    echo "seeding /var from factory"
    cp -a /sysroot/usr/share/factory/var/. /sysroot/var/
fi

# /etc overlay — upper/work live on persistent @var, so /etc survives cascade updates
mkdir -p /sysroot/var/lib/etc/upper /sysroot/var/lib/etc/work
mount -t overlay overlay /sysroot/etc \
    -o lowerdir=/sysroot/usr/etc,upperdir=/sysroot/var/lib/etc/upper,workdir=/sysroot/var/lib/etc/work \
    || { echo "etc overlay failed"; exec sh; }

mount -o bind /dev /sysroot/dev
mount -t tmpfs -o mode=0755,nosuid,nodev tmpfs /sysroot/run
exec switch_root /sysroot /sbin/init

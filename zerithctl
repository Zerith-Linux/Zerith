#!/usr/bin/env python3
"""zerithctl — thin entry point for the Zerith host tooling.

The real work lives in the :mod:`zerith` package. This shim only locates that
package and hands off to its CLI, so the command behaves identically whether
it's run from a checkout or from its installed location (``/usr/lib/zerith``).
"""
from __future__ import annotations

import os
import sys

# When installed on a Zerith host the package ships at /usr/lib/zerith; in a
# checkout it sits next to this file. Add both so `import zerith` resolves
# without needing the package on the default path.
_HERE = os.path.dirname(os.path.realpath(__file__))
for _candidate in ("/usr/lib/zerith", _HERE):
    if os.path.isdir(os.path.join(_candidate, "zerith")):
        sys.path.insert(0, _candidate)
        break

from zerith import main  # noqa: E402  (import after sys.path setup)

if __name__ == "__main__":
    sys.exit(main())

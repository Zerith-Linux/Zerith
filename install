#!/usr/bin/env bash
#
# Zerith bootstrap installer.
#
# A thin wrapper that prepares the environment and then hands the real work to
# `zerithctl install`. It can be run straight from a checkout or piped from the
# web:
#
#     curl -fsSL https://raw.githubusercontent.com/Zerith-Linux/Zerith/main/install | sudo bash
#
# It (1) ensures it is running as root, (2) makes sure the tools the installer
# needs are on PATH, (3) obtains the `zerithctl` package (using the checkout it
# lives in, or fetching one), (4) picks a target disk interactively when none is
# given, and (5) execs `zerithctl install`. All install logic — partitioning,
# layout, landing, promotion — lives in zerithctl; see docs/deployment.md.
set -euo pipefail

# --- Configuration (override via environment) --------------------------------
ZERITH_REF="${ZERITH_REF:-ghcr.io/zerith-linux/zerith:latest}"
ZERITH_REPO="${ZERITH_REPO:-https://github.com/Zerith-Linux/Zerith}"
ZERITH_BRANCH="${ZERITH_BRANCH:-main}"
ZERITH_DISK="${ZERITH_DISK:-}"
ZERITH_INSECURE="${ZERITH_INSECURE:-}"   # set to skip cosign verification (dev)
ZERITH_YES="${ZERITH_YES:-}"             # set to skip the wipe confirmation

# Tools the installer shells out to. Missing ones are installed with pacman when
# available, otherwise reported so the user can add them by hand.
REQUIRED_TOOLS=(python3 oras cosign fsverity mkfs.btrfs mkfs.fat sgdisk
                partprobe mount umount composefs-info curl)

say()  { printf 'install-zerith: %s\n' "$*"; }
warn() { printf 'install-zerith: warning: %s\n' "$*" >&2; }
die()  { printf 'install-zerith: error: %s\n' "$*" >&2; exit 1; }

# --- 1. Ensure root ----------------------------------------------------------
ensure_root() {
    [ "$(id -u)" -eq 0 ] && return 0
    command -v sudo >/dev/null 2>&1 || die "not root and sudo not found"
    say "re-running under sudo"
    exec sudo -E bash "$0" "$@"
}

# --- 2. Ensure the required tools are present --------------------------------
ensure_tools() {
    local missing=()
    local tool
    for tool in "${REQUIRED_TOOLS[@]}"; do
        command -v "$tool" >/dev/null 2>&1 || missing+=("$tool")
    done
    [ "${#missing[@]}" -eq 0 ] && return 0

    say "missing tools: ${missing[*]}"
    if command -v pacman >/dev/null 2>&1; then
        say "installing them with pacman"
        # Map tool names to the Arch packages that provide them.
        pacman -Sy --noconfirm --needed \
            python btrfs-progs dosfstools gptfdisk util-linux composefs \
            fsverity-utils curl cosign || \
            warn "pacman could not install everything; continuing anyway"
    else
        warn "no pacman here — install these yourself before continuing: ${missing[*]}"
    fi

    VERSION="1.3.2"
    curl -LO "https://github.com/oras-project/oras/releases/download/v${VERSION}/oras_${VERSION}_linux_amd64.tar.gz"
    mkdir -p oras-install/
    tar -zxf oras_${VERSION}_*.tar.gz -C oras-install/
    mv oras-install/oras /usr/local/bin/
    rm -rf oras_${VERSION}_*.tar.gz oras-install/
}

# --- 3. Locate or fetch the zerithctl package --------------------------------
# Prints the directory that contains the `zerithctl` script.
locate_tool() {
    local here
    here="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
    if [ -f "$here/zerithctl" ] && [ -d "$here/zerith" ]; then
        echo "$here"
        return 0
    fi
    # Piped from the web with no checkout: fetch one.
    local dest
    dest="$(mktemp -d /tmp/zerith-tool.XXXXXX)"
    if command -v git >/dev/null 2>&1; then
        git clone --depth 1 --branch "$ZERITH_BRANCH" "$ZERITH_REPO" "$dest" \
            >/dev/null 2>&1 || die "failed to clone $ZERITH_REPO"
    else
        command -v curl >/dev/null 2>&1 || die "need git or curl to fetch the tool"
        curl -fsSL "$ZERITH_REPO/archive/refs/heads/$ZERITH_BRANCH.tar.gz" \
            | tar -xz -C "$dest" --strip-components=1 \
            || die "failed to download the tool tarball"
    fi
    echo "$dest"
}

# --- 4. Pick a target disk interactively -------------------------------------
# Sets the global TARGET_DISK. Reads choices from the terminal even when the
# script itself arrived on stdin (curl | bash).
choose_disk() {
    if [ -n "$ZERITH_DISK" ]; then
        TARGET_DISK="$ZERITH_DISK"
        return 0
    fi
    [ -r /dev/tty ] || die "no disk given (set ZERITH_DISK) and no terminal to ask on"

    mapfile -t disks < <(lsblk -dn -o NAME,TYPE | awk '$2=="disk"{print $1}')
    [ "${#disks[@]}" -gt 0 ] || die "no disks found"

    say "select the disk to install Zerith onto (ALL DATA WILL BE ERASED):"
    local i
    for i in "${!disks[@]}"; do
        printf '  [%d] %s\n' "$((i + 1))" \
            "$(lsblk -dn -o NAME,SIZE,MODEL "/dev/${disks[$i]}")" >/dev/tty
    done

    local choice
    while :; do
        printf 'install-zerith: number (or q to quit): ' >/dev/tty
        read -r choice </dev/tty || die "aborted"
        [ "$choice" = "q" ] && die "aborted"
        if [[ "$choice" =~ ^[0-9]+$ ]] && \
           [ "$choice" -ge 1 ] && [ "$choice" -le "${#disks[@]}" ]; then
            TARGET_DISK="/dev/${disks[$((choice - 1))]}"
            return 0
        fi
        warn "invalid choice"
    done
}

# --- 5. Hand off to zerithctl install ----------------------------------------
main() {
    ensure_root "$@"
    ensure_tools

    local tool_dir
    tool_dir="$(locate_tool)"
    say "using zerithctl from $tool_dir"

    local args=(install --ref "$ZERITH_REF")
    [ -n "$ZERITH_INSECURE" ] && args+=(--insecure-skip-verify)
    [ -n "$ZERITH_YES" ] && args+=(--yes)

    # Two modes: existing mountpoints (sysroot + efi), or a whole disk.
    if [ "$#" -eq 2 ]; then
        say "installing onto existing partitions: sysroot=$1 efi=$2"
        args+=("$1" "$2")
    else
        choose_disk
        say "installing onto $TARGET_DISK"
        args+=(--disk "$TARGET_DISK")
    fi

    exec python3 "$tool_dir/zerithctl" "${args[@]}"
}

main "$@"
